{
  "baseUrl": "https://navimow-fra.ninebot.com",
  "vehicleSn": "${NAVIMOW_VEHICLE_SN}",
  "headers": {
    "User-Agent": "NavimowLocalSync/0.1",
    "Content-Type": "application/json",
    "Authorization": "${NAVIMOW_AUTHORIZATION}"
  },
  "routes": [
    "index2",
    "device-info",
    "get-location",
    "set-list",
    "trail-time"
